# ============================================================================
#  contact-center-agents — Plantilla de configuración
#  Copiá a `.env` y completá. NUNCA commitees `.env`.
# ============================================================================

# --- Claude / Anthropic (OBLIGATORIO) -------------------------------------
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Runtime de agentes ----------------------------------------------------
# hybrid: la resolución (clasificar→recuperar→responder→QA) corre como Managed
#         Agent en la plataforma de Claude; el resto en LangGraph. local: todo acá.
AGENT_RUNTIME=hybrid
MANAGED_AGENT_ID=
MANAGED_ENV_ID=

# --- Modelos por agente ----------------------------------------------------
MODEL_CLASSIFIER=claude-sonnet-4-6
MODEL_RETRIEVER=claude-sonnet-4-6
MODEL_RESPONDER=claude-opus-4-8
MODEL_CRITIC=claude-opus-4-8
MODEL_ROUTER=claude-sonnet-4-6

# --- Política de soporte ---------------------------------------------------
COMPANY_NAME=Mi Empresa
SUPPORT_LANGUAGE=es
BRAND_VOICE=cordial, claro y resolutivo
MAX_REVISIONS=2
NUM_TICKETS=10            # cuántos tickets abiertos procesa por corrida

# --- Base de conocimiento (RAG) --------------------------------------------
# Carpeta con artículos .md de la KB (retrieval por keywords; ver docs).
KNOWLEDGE_DIR=knowledge_base

# --- Agenda propia (tool de turnos) ----------------------------------------
# Si AGENDA_ENABLED=true, el redactor puede consultar disponibilidad y RESERVAR
# turnos en nuestra base de datos (tool-use). Útil para casos de agendamiento.
# Para producción, reemplazá integrations/agenda.py por tu sistema real
# (Google Calendar, Calendly, una tabla del CRM, etc.).
AGENDA_ENABLED=false
AGENDA_SEDES=CABA,Morón     # sedes separadas por coma
AGENDA_OPEN_HOUR=10         # horario comercial (apertura)
AGENDA_CLOSE_HOUR=18        # horario comercial (cierre)
AGENDA_SLOT_MINUTES=60      # duración de cada turno

# --- CRM / ticketing (REAL, pluggable) -------------------------------------
# CRM_PROVIDER: generic | zendesk | hubspot
CRM_PROVIDER=generic

# generic: cualquier REST API de tickets (real). Ajustá las rutas en integrations/crm/generic.py
CRM_GENERIC_BASE_URL=
CRM_GENERIC_TOKEN=

# zendesk:
ZENDESK_SUBDOMAIN=
ZENDESK_EMAIL=
ZENDESK_API_TOKEN=

# hubspot:
HUBSPOT_TOKEN=

# --- Notificaciones (escalamiento a humano) --------------------------------
SLACK_WEBHOOK_URL=

# --- ManyChat (omnicanal: WhatsApp / Instagram / Facebook / TikTok / Telegram) ---
# API key: ManyChat → Settings → API. El canal se conecta dentro de ManyChat.
MANYCHAT_API_KEY=
# Token que configurás como header X-Webhook-Token en el External Request del Flow.
MANYCHAT_WEBHOOK_TOKEN=
MANYCHAT_HANDOFF_TAG=handoff-humano

# --- Investigación opcional (Tavily) ---------------------------------------
RESEARCH_BACKEND=claude   # claude | tavily
TAVILY_API_KEY=

# --- Persistencia ----------------------------------------------------------
DATABASE_PATH=output/contact_center.db

# --- Webapp / UI -----------------------------------------------------------
PORT=8080
SCHEDULER_TOKEN=

# --- Login del dashboard ---------------------------------------------------
# Si AUTH_PASSWORD está vacío, login deshabilitado (local). En la nube, definilo.
AUTH_USERNAME=admin
AUTH_PASSWORD=
SESSION_SECRET=cambiá-esto-por-algo-aleatorio

# --- GCP -------------------------------------------------------------------
USE_GCP_SECRETS=false
GCP_PROJECT=supple-framing-498515-a0

# --- Seguridad / ejecución -------------------------------------------------
# DRY_RUN=true -> genera respuestas pero NO las envía al cliente/CRM.
DRY_RUN=true
OUTPUT_DIR=output
